# Copy this file to .env and fill in your key.
# Never commit .env — it is already in .gitignore.

# ── Google Gemini (required) ─────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...           # Required for both embeddings and the LLM
                                 # Get a free key at https://aistudio.google.com/app/apikey

# ── Agent settings (optional overrides) ─────────────────────────────────────
LLM_MODEL=gemini-1.5-flash      # Gemini model name
EMBED_MODEL=models/embedding-001 # Google embedding model (free tier)

# ── Paths (optional — defaults work for the standard repo layout) ────────────
# DATA_DIR=../data
# DB_DIR=./chroma_db
# TICKETS_CSV=../support_tickets/support_tickets.csv
# OUTPUT_CSV=../support_tickets/output.csv
